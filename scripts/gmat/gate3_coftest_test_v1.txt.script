% COF format test: openqfuel_j2_fixed_v1.cof
SolarSystem.EphemerisSource = 'SPICE';
SolarSystem.SPKFilename = '../data/planetary_ephem/spk/de440s.bsp';
Create Spacecraft V01;
V01.DateFormat = UTCGregorian;
V01.Epoch = '04 Apr 2026 11:00:00.000';
V01.CoordinateSystem = EarthMJ2000Eq;
V01.DisplayStateType = Cartesian;
V01.X  = -105310.786419770316570;
V01.Y  = -204917.564511674834648;
V01.Z  = -112666.427079640023294;
V01.VX = -0.217527477574041;
V01.VY = -1.013501925844821;
V01.VZ = -0.551216324422650;
Create ForceModel FM;
FM.CentralBody = Earth;
FM.PrimaryBodies = {Earth};
FM.PointMasses = {};
FM.Drag = None;
FM.SRP = Off;
FM.RelativisticCorrection = Off;
FM.ErrorControl = RSSStep;
FM.GravityField.Earth.Degree = 2;
FM.GravityField.Earth.Order = 0;
FM.GravityField.Earth.PotentialFile = 'openqfuel_j2_fixed_v1.cof';
FM.GravityField.Earth.TideModel = 'None';
Create Propagator P;
P.FM = FM;
P.Type = RungeKutta89;
P.InitialStepSize = 60;
P.Accuracy = 1e-13;
P.MinStep = 0.001;
P.MaxStep = 150;
P.MaxStepAttempts = 50;
P.StopIfAccuracyIsViolated = true;
Create ReportFile Rep;
Rep.Filename = 'test_v1.txt';
Rep.Precision = 16;
Rep.WriteHeaders = false;
BeginMissionSequence;
Propagate P(V01) {V01.ElapsedSecs = 21600.0};
Report Rep V01.ElapsedSecs V01.EarthMJ2000Eq.X V01.EarthMJ2000Eq.Y V01.EarthMJ2000Eq.Z V01.EarthMJ2000Eq.VX V01.EarthMJ2000Eq.VY V01.EarthMJ2000Eq.VZ;
